{
  "name": "qivryn",
  "scripts": {
    "ide:prepare": "node ide/scripts/prepare.mjs",
    "ide:prepare:reset": "node ide/scripts/prepare.mjs --reset",
    "ide:icons": "node ide/scripts/build-icons.mjs",
    "ide:test": "node --test ide/scripts/*.test.mjs",
    "test:package-smoke": "node --test extensions/vscode/scripts/smoke-test-agent-cli.test.mjs",
    "ide:verify": "node ide/scripts/verify.mjs && node ide/scripts/verify-branding.mjs",
    "ide:verify:branding": "node ide/scripts/verify-branding.mjs",
    "ide:install": "node ide/scripts/install.mjs",
    "ide:compile": "node ide/scripts/run-upstream.mjs npm run compile-client",
    "ide:watch": "node ide/scripts/run-upstream.mjs npx npm-run-all2 -lp watch-client-transpile watch-client watch-extensions",
    "ide:run": "node ide/scripts/run.mjs",
    "ide:package:mac": "node ide/scripts/run-upstream.mjs npx gulp vscode-darwin-arm64",
    "ide:package:mac:x64": "QIVRYN_VSCODE_TARGET=darwin-x64 npm run ide:prepare && node ide/scripts/run-upstream.mjs npx gulp vscode-darwin-x64",
    "ide:package:mac:arm64": "QIVRYN_VSCODE_TARGET=darwin-arm64 npm run ide:prepare && node ide/scripts/run-upstream.mjs npx gulp vscode-darwin-arm64",
    "ide:package:linux:x64": "QIVRYN_VSCODE_TARGET=linux-x64 npm run ide:prepare && node ide/scripts/run-upstream.mjs npx gulp vscode-linux-x64",
    "ide:package:linux:arm64": "QIVRYN_VSCODE_TARGET=linux-arm64 npm run ide:prepare && node ide/scripts/run-upstream.mjs npx gulp vscode-linux-arm64",
    "ide:package:win:x64": "QIVRYN_VSCODE_TARGET=win32-x64 npm run ide:prepare && node ide/scripts/run-upstream.mjs npx gulp vscode-win32-x64",
    "ide:package:win:arm64": "QIVRYN_VSCODE_TARGET=win32-arm64 npm run ide:prepare && node ide/scripts/run-upstream.mjs npx gulp vscode-win32-arm64",
    "ide:package:artifact": "node ide/scripts/package-artifacts.mjs",
    "ide:install:mac": "node ide/scripts/install-app.mjs",
    "ide:visual:prepare": "node ide/scripts/prepare-visual-acceptance.mjs",
    "ide:visual:audit": "node ide/scripts/verify-visual-references.mjs",
    "ide:visual:capture": "node ide/scripts/capture-cdp-screenshot.mjs",
    "ide:acceptance:audit": "node ide/scripts/verify-electron-acceptance.mjs",
    "ide:recovery:audit:mac": "node ide/scripts/verify-packaged-recovery.mjs --platform darwin --arch arm64",
    "validate:cursor-parity": "node scripts/validate-cursor-parity.mjs",
    "vsix:build:mac": "bash scripts/build-vsix-macos.sh",
    "vsix:install:mac": "bash scripts/install-vsix-macos.sh",
    "vsix:build:windows": "powershell -ExecutionPolicy Bypass -File scripts/build-vsix-windows.ps1",
    "vsix:install:windows": "powershell -ExecutionPolicy Bypass -File scripts/install-vsix-windows.ps1",
    "build:agent-runtime": "npm --prefix packages/agent-runtime run build",
    "test:agent-runtime": "npm --prefix packages/agent-runtime test",
    "build:review-engine": "npm --prefix packages/review-engine run build",
    "test:review-engine": "npm --prefix packages/review-engine test",
    "build:browser-runtime": "npm --prefix packages/browser-runtime run build",
    "test:browser-runtime": "npm --prefix packages/browser-runtime test",
    "build:slack-connector": "npm --prefix packages/slack-connector run build",
    "test:slack-connector": "npm --prefix packages/slack-connector test",
    "tsc:watch": "concurrently -n gui,vscode,core,binary -c cyan,magenta,yellow,green \"npm run tsc:watch:gui\" \"npm run tsc:watch:vscode\" \"npm run tsc:watch:core\" \"npm run tsc:watch:binary\"",
    "tsc:watch:gui": "tsc --project gui/tsconfig.json --watch --noEmit --pretty",
    "tsc:watch:vscode": "tsc --project extensions/vscode/tsconfig.json --watch --noEmit --pretty",
    "tsc:watch:core": "tsc --project core/tsconfig.json --watch --noEmit --pretty",
    "tsc:watch:binary": "tsc --project binary/tsconfig.json --watch --noEmit --pretty",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\" --ignore-path .gitignore --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\" --ignore-path .gitignore --ignore-path .prettierignore",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,md}": "prettier --write"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.40.0",
    "concurrently": "^9.1.2",
    "eslint": "^8",
    "eslint-plugin-import": "^2.29.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^2.0.20"
  }
}
