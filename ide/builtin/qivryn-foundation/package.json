{
  "name": "qivryn-foundation",
  "displayName": "Qivryn IDE Foundation",
  "description": "Qivryn theme and workbench defaults for the built-in IDE distribution.",
  "version": "0.1.0",
  "publisher": "qivryn",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.127.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Qivryn Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/qivryn-dark-color-theme.json"
      },
      {
        "label": "Qivryn Midnight",
        "uiTheme": "vs-dark",
        "path": "./themes/qivryn-midnight-color-theme.json"
      },
      {
        "label": "Qivryn Light",
        "uiTheme": "vs",
        "path": "./themes/qivryn-light-color-theme.json"
      },
      {
        "label": "Qivryn High Contrast",
        "uiTheme": "hc-black",
        "path": "./themes/qivryn-high-contrast-color-theme.json"
      }
    ],
    "configurationDefaults": {
      "workbench.colorTheme": "Qivryn Dark",
      "workbench.startupEditor": "none",
      "window.commandCenter": true,
      "workbench.layoutControl.enabled": true,
      "workbench.editor.showTabs": "multiple",
      "workbench.editor.enablePreview": false,
      "workbench.editor.tabSizing": "shrink",
      "workbench.editor.pinnedTabSizing": "compact",
      "workbench.panel.defaultLocation": "bottom",
      "workbench.sideBar.location": "left",
      "workbench.secondarySideBar.defaultVisibility": "hidden",
      "terminal.integrated.defaultLocation": "view",
      "chat.viewSessions.enabled": false,
      "chat.viewSessions.orientation": "stacked",
      "chat.agentsControl.enabled": "hidden",
      "chat.agentsHandoffTip.mode": "hidden"
    }
  }
}
