{
  "$schema": "vscode://schemas/color-theme",
  "name": "Qivryn Light",
  "type": "light",
  "colors": {
    "editor.background": "#FAFAFC",
    "editor.foreground": "#20232A",
    "sideBar.background": "#F2F3F7",
    "activityBar.background": "#E9EBF1",
    "panel.background": "#F2F3F7",
    "input.background": "#FFFFFF",
    "input.foreground": "#191B21",
    "focusBorder": "#149DA4",
    "button.background": "#6847F5",
    "button.foreground": "#FFFFFF",
    "list.activeSelectionBackground": "#E2DCFF",
    "terminal.background": "#FFFFFF"
  },
  "tokenColors": [
    {
      "scope": ["comment"],
      "settings": { "foreground": "#596273", "fontStyle": "italic" }
    },
    {
      "scope": ["keyword", "storage"],
      "settings": { "foreground": "#6B32A8" }
    },
    { "scope": ["string"], "settings": { "foreground": "#246B39" } },
    {
      "scope": ["entity.name.function"],
      "settings": { "foreground": "#165CB3" }
    }
  ]
}
