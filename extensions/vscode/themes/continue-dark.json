{
  "$schema": "vscode://schemas/color-theme",
  "name": "Continue Dark",
  "type": "dark",
  "colors": {
    "editor.background": "#181A1F",
    "editor.foreground": "#E6E9EF",
    "sideBar.background": "#14161A",
    "activityBar.background": "#101216",
    "panel.background": "#14161A",
    "input.background": "#20232A",
    "input.foreground": "#F2F4F8",
    "focusBorder": "#8B7CF6",
    "button.background": "#6958D9",
    "button.foreground": "#FFFFFF",
    "list.activeSelectionBackground": "#35304F",
    "terminal.background": "#14161A"
  },
  "tokenColors": [
    {
      "scope": ["comment"],
      "settings": { "foreground": "#9AA3B2", "fontStyle": "italic" }
    },
    {
      "scope": ["keyword", "storage"],
      "settings": { "foreground": "#C7A0FF" }
    },
    { "scope": ["string"], "settings": { "foreground": "#9AD7A8" } },
    {
      "scope": ["entity.name.function"],
      "settings": { "foreground": "#86B8FF" }
    }
  ]
}
