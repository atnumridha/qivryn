{
  "name": "qivryn",
  "icon": "media/icon.png",
  "author": "Qivryn AI",
  "version": "1.3.42",
  "repository": {
    "type": "git",
    "url": "https://github.com/atnumridha/qivryn"
  },
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "bugs": {
    "url": "https://github.com/atnumridha/qivryn/issues",
    "email": "nate@qivryn.ai"
  },
  "homepage": "https://qivryn.ai",
  "qna": "https://github.com/atnumridha/qivryn/issues/new/choose",
  "license": "Apache-2.0",
  "displayName": "Qivryn - open-source AI code agent",
  "pricing": "Free",
  "description": "The leading open-source AI code agent",
  "publisher": "Qivryn",
  "engines": {
    "vscode": "^1.70.0",
    "node": ">=20.20.1"
  },
  "engine-strict": true,
  "galleryBanner": {
    "color": "#1E1E1E",
    "theme": "dark"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages",
    "Education",
    "Machine Learning",
    "Snippets"
  ],
  "keywords": [
    "chatgpt",
    "cline",
    "roo",
    "github",
    "copilot",
    "claude",
    "mistral",
    "codestral",
    "ai"
  ],
  "activationEvents": [
    "onUri",
    "onStartupFinished",
    "onWebviewPanel:qivryn.qivrynGUIView",
    "onView:qivrynGUIView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "themes": [
      {
        "label": "Qivryn Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/qivryn-dark.json"
      },
      {
        "label": "Qivryn Midnight",
        "uiTheme": "vs-dark",
        "path": "./themes/qivryn-midnight.json"
      },
      {
        "label": "Qivryn Light",
        "uiTheme": "vs",
        "path": "./themes/qivryn-light.json"
      },
      {
        "label": "Qivryn High Contrast",
        "uiTheme": "hc-black",
        "path": "./themes/qivryn-high-contrast.json"
      }
    ],
    "languages": [
      {
        "filenames": [
          "config.json",
          ".qivrynrc.json"
        ],
        "id": "jsonc"
      },
      {
        "id": "promptLanguage",
        "extensions": [
          ".prompt"
        ],
        "aliases": [
          "Prompt Language"
        ],
        "configuration": "./prompt-file-language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "promptLanguage",
        "scopeName": "source.prompt",
        "path": "./media/prompt.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Qivryn",
      "properties": {
        "qivryn.telemetryEnabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Qivryn collects anonymous usage data, cleaned of PII, to help us improve the product for our users. Read more  at [qivryn.ai › Telemetry](https://docs.qivryn.ai/telemetry).",
          "markdownDeprecationMessage": "This setting is deprecated and will be removed in a later version. Please use the _Telemetry > Allow Anonymous Telemetry_ setting in the extension's User Settings page.",
          "deprecationMessage": "Please use the _Telemetry > Allow Anonymous Telemetry_ setting in the extension's User Settings page."
        },
        "qivryn.showInlineTip": {
          "type": "boolean",
          "default": true,
          "description": "Show inline suggestion to use the Qivryn keyboard shortcuts (e.g. \"Cmd/Ctrl L to select code, Cmd/Ctrl I to edit\")."
        },
        "qivryn.disableQuickFix": {
          "type": "boolean",
          "default": false,
          "description": "Disable the quick fix feature."
        },
        "qivryn.enableQuickActions": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Enable the experimental Quick Actions feature. Read our walkthrough to learn about configuration and how to share feedback: [qivryn.ai › Walkthrough: Quick Actions (experimental)](https://docs.qivryn.ai/customize/deep-dives/vscode-actions#quick-actions)"
        },
        "qivryn.enableTabAutocomplete": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Enable Qivryn's tab autocomplete feature. Read our walkthrough to learn about configuration and how to share feedback: [qivryn.ai › Walkthrough: Tab Autocomplete (beta)](https://docs.qivryn.ai/features/tab-autocomplete)"
        },
        "qivryn.enableNextEdit": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Enable Qivryn's next edit feature. Read our docs to learn about configuration and how to share feedback: [qivryn.ai › Features › Autocomplete › Next Edit (experimental)](https://docs.qivryn.ai/features/autocomplete/next-edit)"
        },
        "qivryn.pauseTabAutocompleteOnBattery": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Pause Qivryn's tab autocomplete feature when your battery is low."
        },
        "qivryn.pauseCodebaseIndexOnStart": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Pause Qivryn's codebase index on start."
        },
        "qivryn.enableConsole": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Enable a console to log and explore model inputs and outputs. It can be found in the bottom panel."
        },
        "qivryn.agentCompletionNotifications": {
          "type": "string",
          "enum": [
            "off",
            "whenUnfocused",
            "always"
          ],
          "enumDescriptions": [
            "Do not show completion notifications.",
            "Notify only when the editor window is not focused.",
            "Notify whenever an agent completes, fails, or needs attention."
          ],
          "default": "whenUnfocused",
          "description": "Controls native notifications for background agent completion."
        },
        "qivryn.agentNotificationIncludeTaskTitle": {
          "type": "boolean",
          "default": false,
          "description": "Include the agent task title in native notifications. Disabled by default to avoid exposing project details."
        },
        "qivryn.enableAiAttribution": {
          "type": "boolean",
          "default": true,
          "description": "Show CodeLens links from agent-generated lines to their originating conversation."
        },
        "qivryn.remoteConfigServerUrl": {
          "type": "string",
          "default": null,
          "markdownDescription": "If your team is set up to use shared configuration, enter the server URL here and your user token below to enable automatic syncing."
        },
        "qivryn.userToken": {
          "type": "string",
          "default": null,
          "markdownDescription": "If your team is set up to use shared configuration, enter your user token here and your server URL above to enable automatic syncing."
        },
        "qivryn.remoteConfigSyncPeriod": {
          "type": "number",
          "default": 60,
          "description": "The period of time in minutes between automatic syncs."
        }
      }
    },
    "commands": [
      {
        "command": "qivryn.applyCodeFromChat",
        "category": "Qivryn",
        "title": "Apply code from chat",
        "group": "Qivryn"
