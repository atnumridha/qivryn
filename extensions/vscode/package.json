    "keybindings": [
      {
        "command": "qivryn.acceptNextSuggestionWord",
        "key": "alt+right",
        "mac": "alt+right",
        "when": "inlineSuggestionVisible"
      },
      {
        "command": "qivryn.acceptNextSuggestionLine",
        "key": "shift+alt+right",
        "mac": "shift+alt+right",
        "when": "inlineSuggestionVisible"
      },
      {
        "command": "qivryn.focusQivrynInput",
        "mac": "cmd+l",
        "key": "ctrl+l"
      },
      {
        "command": "qivryn.focusQivrynInputWithoutClear",
        "mac": "cmd+shift+l",
        "key": "ctrl+shift+l"
      },
      {
        "command": "qivryn.acceptDiff",
        "mac": "shift+cmd+enter",
        "key": "shift+ctrl+enter",
        "when": "qivryn.diffVisible"
      },
      {
        "command": "qivryn.rejectDiff",
        "mac": "shift+cmd+backspace",
        "key": "shift+ctrl+backspace",
        "when": "qivryn.diffVisible"
      },
      {
        "command": "qivryn.rejectDiff",
        "mac": "cmd+z",
        "key": "ctrl+z",
        "when": "qivryn.diffVisible"
      },
      {
        "command": "qivryn.quickEditHistoryUp",
        "mac": "up",
        "key": "up",
        "when": "false && qivryn.quickEditHistoryFocused"
      },
      {
        "command": "qivryn.quickEditHistoryDown",
        "mac": "down",
        "key": "down",
        "when": "false && qivryn.quickEditHistoryFocused"
      },
      {
        "command": "qivryn.acceptVerticalDiffBlock",
        "mac": "alt+cmd+y",
        "key": "alt+ctrl+y"
      },
      {
        "command": "qivryn.rejectVerticalDiffBlock",
        "mac": "alt+cmd+n",
        "key": "alt+ctrl+n"
      },
      {
        "command": "qivryn.focusEdit",
        "title": "Edit code with natural language",
        "mac": "cmd+i",
        "key": "ctrl+i"
      },
      {
        "command": "qivryn.exitEditMode",
        "mac": "escape",
        "key": "escape",
        "when": "qivryn.inEditMode && editorFocus"
      },
      {
        "command": "qivryn.debugTerminal",
        "mac": "cmd+shift+r",
        "key": "ctrl+shift+r"
      },
      {
        "command": "qivryn.openInNewWindow",
        "mac": "cmd+k cmd+m",
        "key": "ctrl+k ctrl+m",
        "when": "!terminalFocus"
      },
      {
        "command": "qivryn.toggleTabAutocompleteEnabled",
        "mac": "cmd+k cmd+a",
        "key": "ctrl+k ctrl+a",
        "when": "!terminalFocus"
      },
      {
        "command": "qivryn.forceAutocomplete",
        "key": "ctrl+alt+space",
        "mac": "cmd+alt+space",
        "when": "editorTextFocus && !editorHasSelection && !editorReadOnly && !inSnippetMode"
      },
      {
        "command": "qivryn.applyCodeFromChat",
        "mac": "alt+a",
        "key": "alt+a"
      },
      {
        "command": "qivryn.toggleNextEditEnabled",
        "key": "ctrl+k ctrl+n",
        "mac": "cmd+k cmd+n",
        "when": "editorTextFocus"
      },
      {
        "command": "qivryn.nextEditWindow.hideNextEditSuggestion",
        "key": "escape",
        "when": "editorTextFocus && nextEditWindowActive && !qivryn.jumpDecorationVisible"
      },
      {
        "command": "qivryn.nextEditWindow.acceptNextEditSuggestion",
        "key": "tab",
        "when": "editorTextFocus && nextEditWindowActive && !qivryn.jumpDecorationVisible"
      },
      {
        "command": "qivryn.acceptJump",
        "key": "tab",
        "when": "editorTextFocus && qivryn.jumpDecorationVisible"
      },
      {
        "command": "qivryn.rejectJump",
        "key": "escape",
        "when": "editorTextFocus && qivryn.jumpDecorationVisible"
      }
    ],
    "submenus": [
      {
        "id": "qivryn.qivrynSubMenu",
        "label": "Qivryn"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "qivryn.focusQivrynInput"
        },
        {
          "command": "qivryn.focusQivrynInputWithoutClear"
        },
        {
          "command": "qivryn.debugTerminal"
        },
        {
          "command": "qivryn.newSession"
        },
        {
          "command": "qivryn.enterEnterpriseLicenseKey"
        },
        {
          "command": "qivryn.openInNewWindow"
        },
        {
          "command": "qivryn.openAgentsWindow"
        },
        {
          "command": "qivryn.switchAgent"
        },
        {
          "command": "qivryn.openAgentReview"
        },
        {
          "command": "qivryn.openTerminalAssistant"
        },
        {
          "command": "qivryn.openBrowserWorkspace"
        },
        {
          "command": "qivryn.openAgentAttribution"
        },
        {
          "command": "qivryn.chooseLayout"
        },
        {
          "command": "qivryn.saveLayout"
        },
        {
          "command": "qivryn.openAgentGraph"
        },
        {
          "command": "qivryn.generateCommitMessage"
        },
        {
          "command": "qivryn.openSlackConnector"
        },
        {
          "command": "qivryn.exportAgentDiagnostics"
        }
      ],
      "editor/context": [
        {
          "submenu": "qivryn.qivrynSubMenu",
          "group": "0_aqivryn"
        }
      ],
      "editor/title/run": [
        {
          "command": "qivryn.rejectDiff",
          "group": "Qivryn",
          "when": "qivryn.streamingDiff"
        }
      ],
      "qivryn.qivrynSubMenu": [
        {
          "command": "qivryn.focusQivrynInputWithoutClear",
          "group": "Qivryn"
        },
        {
          "command": "qivryn.focusEdit",
          "group": "Qivryn",
          "when": "!editorReadonly"
        }
      ],
      "explorer/context": [
        {
          "command": "qivryn.selectFilesAsContext",
          "group": "1_debug@1"
        }
      ],
      "view/title": [
        {
          "command": "qivryn.newSession",
          "group": "navigation@1",
          "when": "view == qivryn.qivrynGUIView"
        },
        {
          "command": "qivryn.viewHistory",
          "group": "navigation@2",
          "when": "view == qivryn.qivrynGUIView"
        },
        {
          "command": "qivryn.openAgentsWindow",
          "group": "navigation@3",
          "when": "view == qivryn.qivrynGUIView"
        },
        {
          "command": "qivryn.openAgentReview",
          "group": "navigation@4",
          "when": "view == qivryn.qivrynGUIView"
        },
        {
          "command": "qivryn.openConfigPage",
          "group": "navigation@5",
          "when": "view == qivryn.qivrynGUIView"
        },
        {
          "command": "qivryn.clearConsole",
          "group": "navigation@1",
          "when": "view == qivryn.qivrynConsoleView"
        }
      ],
      "editor/title": [
        {
          "command": "qivryn.reloadAgentsWindow",
          "group": "navigation@0",
          "when": "activeWebviewPanelId == qivryn.qivrynGUIView"
        },
        {
          "command": "qivryn.newSession",
          "group": "navigation@1",
          "when": "activeWebviewPanelId == qivryn.qivrynGUIView"
        },
        {
          "command": "qivryn.viewHistory",
          "group": "navigation@2",
          "when": "activeWebviewPanelId == qivryn.qivrynGUIView"
        },
        {
          "command": "qivryn.openAgentsWindow",
          "group": "navigation@3",
          "when": "activeWebviewPanelId == qivryn.qivrynGUIView"
        },
        {
          "command": "qivryn.openAgentReview",
          "group": "navigation@4",
          "when": "activeWebviewPanelId == qivryn.qivrynGUIView"
        }
      ],
      "terminal/context": [
        {
          "command": "qivryn.openTerminalPromptBar",
          "group": "navigation@top"
        },
        {
          "command": "qivryn.openTerminalAssistant",
          "group": "navigation@1"
        },
        {
          "command": "qivryn.debugTerminal",
          "group": "navigation@2"
        }
      ],
      "terminal/title/context": [
        {
          "command": "qivryn.openTerminalPromptBar",
          "group": "navigation@top"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "qivryn",
          "title": "Qivryn",
          "icon": "media/sidebar-icon.png"
        }
      ],
      "panel": [
        {
          "id": "qivrynConsole",
          "title": "Qivryn Console",
          "icon": "$(window)"
        }
      ]
    },
    "views": {
      "qivryn": [
        {
          "type": "webview",
          "id": "qivryn.qivrynGUIView",
          "name": "Qivryn",
          "icon": "media/sidebar-icon.png",
          "visibility": "visible"
        }
      ],
      "qivrynConsole": [
        {
          "type": "webview",
          "id": "qivryn.qivrynConsoleView",
          "name": "Qivryn Console",
          "icon": "$(window)",
          "visibility": "visible",
          "when": "config.qivryn.enableConsole"
        }
      ]
    },
    "jsonValidation": [
      {
        "fileMatch": "**/.qivryn*/config.json",
        "url": "./config_schema.json"
      },
      {
        "fileMatch": ".qivrynrc.json",
        "url": "./qivryn_rc_schema.json"
      },
      {
        "fileMatch": "**/config.yaml",
        "url": "./config-yaml-schema.json"
      }
    ]
  },
  "scripts": {
    "esbuild-base": "node scripts/esbuild.js",
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "esbuild-notify": "npm run esbuild-base -- --sourcemap --notify",
    "esbuild:visualize": "esbuild-visualizer --metadata ./build/meta.json --filename ./build/stats.html --open",
    "tsc": "tsc -p ./",
    "tsc:check": "tsc -p ./ --noEmit",
    "tsc-watch": "tsc -watch -p ./",
    "rebuild": "electron-rebuild -v 19.1.8 node-pty",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint . --ext ts --fix",
    "test": "vitest run",
    "vitest": "vitest run",
    "write-build-timestamp": "node scripts/write-build-timestamp.js",
    "prepackage": "node scripts/prepackage.js",
    "package": "node scripts/package.js",
    "package-all": "node scripts/package-all.js",
    "package:pre-release": "node scripts/package.js --pre-release",
    "build:rust": "cargo-cp-artifact -ac sync sync.node -- cargo build --manifest-path ../../sync/Cargo.toml --message-format=json-render-diagnostics",
    "build-debug:rust": "npm run build:rust --",
    "build-release:rust": "npm run build:rust -- --release",
    "e2e:compile": "tsc -p ./tsconfig.e2e.json",
    "e2e:build": "npm --prefix ../../gui run build && npm run package",
    "e2e:create-storage": "mkdir -p ./e2e/storage",
    "e2e:get-chromedriver": "extest get-chromedriver --storage ./e2e/storage --code_version 1.95.0",
    "e2e:get-vscode": "extest get-vscode --storage ./e2e/storage --code_version 1.95.0",
    "e2e:sign-vscode": "codesign --entitlements entitlements.plist --deep --force -s - './e2e/storage/Visual Studio Code.app'",
    "e2e:copy-vsix": "chmod +x ./e2e/get-latest-vsix.sh && bash ./e2e/get-latest-vsix.sh",
    "e2e:install-vsix": "extest install-vsix -f ./e2e/vsix/qivryn.vsix --extensions_dir ./e2e/.test-extensions --storage ./e2e/storage",
    "e2e:install-extensions": "extest install-from-marketplace ms-vscode-remote.remote-ssh --extensions_dir ./e2e/.test-extensions --storage ./e2e/storage && extest install-from-marketplace ms-vscode-remote.remote-containers --extensions_dir ./e2e/.test-extensions --storage ./e2e/storage && extest install-from-marketplace ms-vscode-remote.remote-wsl --extensions_dir ./e2e/.test-extensions --storage ./e2e/storage",
    "e2e:test": "NODE_ENV=e2e extest run-tests ${TEST_FILE:-'./e2e/_output/tests/*.test.js'} --code_settings settings.json --extensions_dir ./e2e/.test-extensions --storage ./e2e/storage",
    "e2e:clean": "rm -rf ./e2e/_output ./e2e/storage",
    "e2e:all": "npm run e2e:build && npm run e2e:compile && npm run e2e:create-storage && npm run e2e:get-chromedriver && npm run e2e:get-vscode && npm run e2e:sign-vscode && npm run e2e:copy-vsix && npm run e2e:install-vsix && npm run e2e:install-extensions && QIVRYN_GLOBAL_DIR=e2e/test-qivryn npm run e2e:test && npm run e2e:clean",
    "e2e:all-non-mac": "npm run e2e:build && npm run e2e:compile && npm run e2e:create-storage && npm run e2e:get-chromedriver && npm run e2e:get-vscode && npm run e2e:copy-vsix && npm run e2e:install-vsix && npm run e2e:install-extensions && QIVRYN_GLOBAL_DIR=e2e/test-qivryn npm run e2e:test && npm run e2e:clean",
    "e2e:recompile-extension": "npm run package && npm run e2e:compile && npm run e2e:copy-vsix && npm run e2e:install-vsix && npm run e2e:install-extensions && QIVRYN_GLOBAL_DIR=e2e/test-qivryn npm run e2e:test && npm run e2e:clean",
    "e2e:rebuild-gui": "rm -rf gui && cp -r ../../gui/dist gui && npm run package && npm run e2e:copy-vsix && npm run e2e:install-vsix && npm run e2e:install-extensions && QIVRYN_GLOBAL_DIR=e2e/test-qivryn npm run e2e:test && npm run e2e:clean",
    "e2e:quick": "npm run e2e:compile && QIVRYN_GLOBAL_DIR=e2e/test-qivryn npm run e2e:test && npm run e2e:clean",
    "e2e:ci:download": "npm run e2e:create-storage && npm run e2e:get-chromedriver && npm run e2e:get-vscode",
    "e2e:ci:run": "npm run e2e:compile && npm run e2e:copy-vsix && npm run e2e:install-vsix && npm run e2e:install-extensions && QIVRYN_GLOBAL_DIR=e2e/test-qivryn npm run e2e:test",
    "e2e:ci:run-yaml": "npm run e2e:compile && npm run e2e:copy-vsix && npm run e2e:install-vsix && npm run e2e:install-extensions && QIVRYN_GLOBAL_DIR=e2e/test-qivryn-yaml npm run e2e:test"
  },
