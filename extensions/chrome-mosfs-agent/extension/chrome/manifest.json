{
  "manifest_version": 3,
  "name": "Qivryn",
  "description": "Qivryn browser assistant for MOSFS analysis, guarded updates, active-tab context, and browser control.",
  "version": "0.1.0",
  "key": "",
  "minimum_chrome_version": "116",
  "permissions": [
    "activeTab",
    "debugger",
    "nativeMessaging",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Qivryn",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/qivryn-16.png",
      "32": "assets/qivryn-32.png",
      "48": "assets/qivryn-48.png",
      "128": "assets/qivryn-128.png"
    }
  },
  "icons": {
    "16": "assets/qivryn-16.png",
    "32": "assets/qivryn-32.png",
    "48": "assets/qivryn-48.png",
    "128": "assets/qivryn-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "qivryn/*",
        "qivryn/assets/*",
        "qivryn-host.css",
        "qivryn-host.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
